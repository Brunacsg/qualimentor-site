# =====================================
# CONFIGURAÇÃO DE AMBIENTE
# =====================================
# 
# Copie este arquivo para um local seguro e defina as variáveis
# antes de iniciar o servidor
#
# No Windows (PowerShell):
#   set VARIAVEL=valor
#
# No Linux/Mac:
#   export VARIAVEL=valor
#
# =====================================

# OBRIGATÓRIO - Senha para operações administrativas
ADMIN_SECRET=sua_senha_admin_super_secreta_aqui

# OPCIONAL - Caminho do SQLite (no Render, prefira usar RENDER_DISK_PATH)
DB_PATH=

# OPCIONAL - Email do administrador (recebe notificações)
ADMIN_EMAIL=admin@seudominio.com

# =====================================
# CONFIGURAÇÃO SMTP (Envio de Emails)
# =====================================
# SE NÃO CONFIGURAR: Emails serão exibidos apenas no console
#
# Exemplos de provedores:
#
# GMAIL:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=seu-email@gmail.com
#   SMTP_PASS=sua-senha-app (gere em myaccount.google.com)
#
# OUTLOOK:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_USER=seu-email@outlook.com
#   SMTP_PASS=sua-senha
#
# SENDGRID:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=sua-api-key
#
# MAILGUN:
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_USER=seu-email@mg.seudominio.com
#   SMTP_PASS=sua-api-key

SMTP_HOST=seu-smtp-server.com
SMTP_PORT=587
SMTP_USER=seu-email@dominio.com
SMTP_PASS=sua-senha-email

# =====================================
# NOTA: Não compartilhe este arquivo!
# =====================================
